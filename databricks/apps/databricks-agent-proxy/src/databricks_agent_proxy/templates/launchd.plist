<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.databricks.agent-proxy</string>
    <key>ProgramArguments</key>
    <array>
        <string>${uvx_path}</string>
        <string>databricks-agent-proxy</string>
        <string>start</string>
        <string>--gateway-url</string>
        <string>${gateway_url}</string>
        <string>--port</string>
        <string>${port}</string>
    </array>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>StandardOutPath</key>
    <string>${log_dir}/databricks-agent-proxy.log</string>
    <key>StandardErrorPath</key>
    <string>${log_dir}/databricks-agent-proxy.err</string>
</dict>
</plist>
