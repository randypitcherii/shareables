# Copy this file into one of:
# - dev.env
# - test.env
# - prod.env
#
# Select active runtime file with:
# APP_ENV=dev|test|prod

# Databricks SQL metadata access
DATABRICKS_HOST=
DATABRICKS_PROFILE=
DATABRICKS_SQL_WAREHOUSE_ID=
# Alternative to warehouse ID if you prefer explicit path
# DATABRICKS_SQL_HTTP_PATH=/sql/1.0/warehouses/<warehouse-id>

# Optional Databricks model serving endpoint for proposal generation
DATABRICKS_SERVING_ENDPOINT=databricks-claude-sonnet-4-5

# Lakebase Postgres persistence
PGHOST=
PGPORT=5432
PGDATABASE=
PGUSER=

# Optional local metadata cache for rapid frontend/backend development
UC_METADATA_SQLITE_PATH=.cache/uc_metadata_cache.db

# Runtime selector used by app.py
APP_ENV=dev
