# Copy to .env and fill in. The real .env is gitignored.
#
# Auth is opinionated and PAT-free:
#   - Local dev: user SSO via `databricks auth login` + a CLI profile below.
#   - CI / prod jobs: service principal creds (DATABRICKS_CLIENT_ID /
#     DATABRICKS_CLIENT_SECRET) injected by the environment.
#   - Deployed serving endpoint: ambient runtime identity, no creds needed.
# The code never branches on auth type — it relies on SDK default credential
# resolution. DATABRICKS_TOKEN (PATs) are intentionally NOT supported.

# --- Auth (local dev) -------------------------------------------------------
# Databricks CLI profile from ~/.databrickscfg (created by `databricks auth login`).
DATABRICKS_PROFILE=DEFAULT

# --- Required -----------------------------------------------------------------
# Genie space ID from the space URL: .../genie/spaces/<GENIE_SPACE_ID>
GENIE_SPACE_ID=

# Unity Catalog home for the web_search UDF and the registered agent model.
# You need CREATE FUNCTION on {BASE_CATALOG}.{BASE_SCHEMA}.
BASE_CATALOG=
BASE_SCHEMA=simple_dispatcher

# --- Optional (has defaults) --------------------------------------------------
# Databricks chat model serving endpoint that backs the dispatcher.
LLM_ENDPOINT=databricks-claude-sonnet-4-6

# MLflow experiment path override. If unset, agent.py uses a per-user default
# (see README "Viewing traces").
MLFLOW_EXPERIMENT=
