# Copy this file to `.env` and fill in the REQUIRED values. `.env` is gitignored.
#
# Loading:
#   * dbt Core v1.12+ / dbt Fusion auto-load `.env` from the current directory.
#   * On older dbt (this project pins dbt-core 1.11 via dbt-databricks), load it
#     yourself first:
#         set -a; source .env; set +a
#
# -----------------------------------------------------------------------------
# REQUIRED for every target (no in-repo fallback -- workspace-specific, and we
# don't publish internal infrastructure identifiers):
# -----------------------------------------------------------------------------
DBT_HOST=your-workspace.cloud.databricks.com
DBT_HTTP_PATH=/sql/1.0/warehouses/your_sql_warehouse_id

# -----------------------------------------------------------------------------
# OPTIONAL dev overrides (these DO have safe in-repo fallbacks):
# -----------------------------------------------------------------------------
# DBT_DEPLOYMENT_ENVIRONMENT=development          # development | ci_testing | production
# DBT_DEFAULT_CATALOG=analytics_dev              # default; set to your own catalog
# DBT_DEFAULT_SCHEMA=dbt
# DBT_DEV_USER=your_name                          # else derived from OS $USER -> dbt_<user>
# DBT_USAGE_HISTORY_DAYS=14                        # smaller = faster demo builds (default 90)

# -----------------------------------------------------------------------------
# CI / PROD only (M2M OAuth service principal) -- set these in your CI/secret
# store, NOT in a committed file. The secret uses the DBT_ENV_SECRET_ prefix so
# dbt masks it in logs and forbids it outside profiles.yml.
# -----------------------------------------------------------------------------
# DBT_CLIENT_ID=...
# DBT_ENV_SECRET_DATABRICKS_CLIENT_SECRET=...
